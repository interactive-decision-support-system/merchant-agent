# Merchant-agent backend environment
#
# Copy this file to apps/backend/.env and fill in real values. Do not commit
# apps/backend/.env.

# Required: direct Postgres connection for Supabase-hosted merchant tables.
# Prefer the pooled Supabase connection string for deployed services.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Required for LLM-backed enrichment and catalog ingestion.
OPENAI_API_KEY="sk-REPLACE-ME"

# Optional fallback product-store access when DATABASE_URL is unavailable for
# legacy read paths. Direct DATABASE_URL access is preferred for merchant tables.
SUPABASE_URL="https://PROJECT_ID.supabase.co"
SUPABASE_KEY="REPLACE_ME"

# Optional Langfuse tracing for enrichment runs.
LANGFUSE_PUBLIC_KEY="pk-lf-REPLACE-ME"
LANGFUSE_SECRET_KEY="sk-lf-REPLACE-ME"
LANGFUSE_HOST="https://cloud.langfuse.com"

# Optional local JSONL trace mirror for the Streamlit inspector.
ENRICHMENT_TRACE_JSONL=0
# ENRICHMENT_TRACE_JSONL_DIR="logs/enrichment_traces"
# ENRICHMENT_TRACE_DISABLED=0

# Optional Redis / Upstash configuration for cache/session integrations.
REDIS_HOST="localhost"
REDIS_PORT=6379
UPSTASH_REDIS_URL="rediss://default:REPLACE_ME@HOST:6379"
UPSTASH_REDIS_REST_URL="https://REPLACE_ME.upstash.io"
UPSTASH_REDIS_REST_TOKEN="REPLACE_ME"

# Optional Neo4j knowledge graph configuration.
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="REPLACE_ME"

# API/runtime toggles.
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS="*"
ALLOW_MERCHANT_DROP=0

# Optional: lets the Streamlit inspector prefer the HTTP admin surface before
# falling back to direct DB reads.
MERCHANT_ADMIN_HOST="http://127.0.0.1:8001"
